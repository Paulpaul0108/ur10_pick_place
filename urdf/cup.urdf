<?xml version="1.0"?>
<robot name="simple_cube">
  <link name="cube_link">
    <inertial>
      <mass value="0.05"/> 
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    
    <visual>
      <geometry>
        <box size="0.06 0.06 0.1"/>
      </geometry>
      <material name="Red">
        <color rgba="0.8 0.0 0.0 1.0"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <box size="0.06 0.06 0.1"/>
      </geometry>
    </collision>
  </link>

  <gazebo reference="cube_link">
    <material>Gazebo/Red</material>
    <mu1>100.0</mu1> 
    <mu2>100.0</mu2>
    <minDepth>0.001</minDepth> 
    <kp>100000.0</kp> 
    <kd>1.0</kd>      
  </gazebo>
</robot>